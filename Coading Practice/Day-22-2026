## Ansible — Use Handler on Config Change

---
- name: Configure Nginx for Pathnex
hosts: all
become: yes

tasks:
 - name: copy Nginx config
   copy:
   dest: /etc/nginx/nginx.comf
   content: |
    user nginx;
    worker_processes auto;
  notify: Restart nginx

handlers:
 - name: Restart nginx
   service:
    name: nginx
    state: restarted

## erraform — Security Group

reource "aws_security_group" "PathnexSG {
  name = "pathnex-sg"
  vpc_id = aws_vpc.PathnexVPC.id

  ingrerss {
    from_port = 80
    to_port = 80
    protocol = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    }
    tags = {
      Name = "Pathnex-SG"
    }
}


